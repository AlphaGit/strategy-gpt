{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://strategy-gpt.local/experiment-spec.schema.json",
  "title": "ExperimentSpec",
  "description": "Single-file declarative definition of a strategy-gpt backtest experiment. Consumed by `strategy-gpt run --spec <file>`. See docs/experiment-spec.md.",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact", "bars", "runs"],
  "properties": {
    "artifact": {
      "type": "string",
      "description": "Filesystem path to the compiled strategy cdylib. Relative paths resolve against the spec file's directory."
    },
    "strategy_label": {
      "type": ["string", "null"],
      "description": "Opaque label recorded as BatchSpec.strategy. Defaults to the artifact filename stem."
    },
    "bars": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["dataset"],
          "properties": {
            "dataset": {
              "type": "string",
              "description": "Manifest hash of a cache-resident dataset."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["request"],
          "properties": {
            "request": { "$ref": "#/$defs/BarRequest" }
          }
        }
      ]
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fill_model": { "enum": ["NextBarOpen", "CurrentBarClose"], "default": "NextBarOpen" },
        "initial_capital": { "type": "number", "default": 100000.0 },
        "commission_per_fill": { "type": "number", "default": 0.0 },
        "sanity": { "$ref": "#/$defs/SanityBounds" }
      },
      "description": "User-facing engine configuration. `slippage_bps` is NOT permitted here; express per-fill slippage as a Slippage mode on a run."
    },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/RunConfig" }
    },
    "optimize": {
      "$ref": "#/$defs/OptimizeBlock",
      "description": "Optional declarative parameter search over the run template. Requires `folds`."
    },
    "folds": {
      "$ref": "#/$defs/FoldsBlock",
      "description": "Optional fold scheme that splits the experiment's slice into train/OOS pairs."
    },
    "parallelism": {
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "const": "auto" }
      ],
      "default": 1
    },
    "caps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "time_cap_secs": { "type": ["number", "null"] },
        "mem_cap_bytes": { "type": ["integer", "null"] }
      }
    }
  },
  "$defs": {
    "BarRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "symbol", "start", "end", "resolution", "adjustment"],
      "properties": {
        "provider": { "type": "string" },
        "symbol": { "type": "string" },
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" },
        "resolution": { "enum": ["Minute", "FiveMinute", "FifteenMinute", "Hour", "Day", "Week"] },
        "adjustment": { "enum": ["raw", "back_adjusted"] },
        "secondary_providers": { "type": "array", "items": { "type": "string" }, "default": [] }
      }
    },
    "SanityBounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_intent_size", "max_position_size"],
      "properties": {
        "max_intent_size": { "type": "number" },
        "max_position_size": { "type": "number" }
      }
    },
    "TimeRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" }
      }
    },
    "RunConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slice"],
      "properties": {
        "params": { "type": "object", "default": {} },
        "modes": {
          "type": "array",
          "default": [{ "kind": "plain" }],
          "items": { "$ref": "#/$defs/Mode" }
        },
        "seed": { "type": "integer", "default": 0 },
        "slice": { "$ref": "#/$defs/TimeRange" }
      }
    },
    "Mode": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["plain", "monte_carlo", "slippage", "regime_filter", "sensitivity"] }
      }
    },
    "FoldsBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["count", "scheme"],
      "properties": {
        "count": { "type": "integer", "minimum": 2 },
        "scheme": { "enum": ["rolling", "anchored"] },
        "gap": { "type": "integer", "minimum": 0, "default": 0 },
        "warmup_bars": { "type": "integer", "minimum": 0 }
      }
    },
    "OptimizeBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "space", "persist"],
      "properties": {
        "method": { "enum": ["recursive_grid", "grid", "random", "bayesian"] },
        "seed": { "type": "integer", "default": 0 },
        "aggregator": { "enum": ["mean"], "default": "mean" },
        "space": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/ParamSpace" }
        },
        "grid": { "$ref": "#/$defs/GridKnobs" },
        "random": { "$ref": "#/$defs/RandomKnobs" },
        "bayesian": { "$ref": "#/$defs/BayesianKnobs" },
        "recursive_grid": { "$ref": "#/$defs/RecursiveGridKnobs" },
        "persist": { "$ref": "#/$defs/PersistBlock" }
      }
    },
    "ParamSpace": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "low", "high"],
          "properties": {
            "type": { "const": "float" },
            "low": { "type": "number" },
            "high": { "type": "number" },
            "step": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "low", "high"],
          "properties": {
            "type": { "const": "int" },
            "low": { "type": "integer" },
            "high": { "type": "integer" },
            "step": { "type": "integer", "exclusiveMinimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "choices"],
          "properties": {
            "type": { "const": "choice" },
            "choices": { "type": "array", "minItems": 1 }
          }
        }
      ]
    },
    "GridKnobs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "resolution": { "type": "integer", "minimum": 2 }
      }
    },
    "RandomKnobs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["n_samples"],
      "properties": {
        "n_samples": { "type": "integer", "minimum": 1 }
      }
    },
    "BayesianKnobs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["n_iter"],
      "properties": {
        "n_init": { "type": "integer", "minimum": 1, "default": 8 },
        "n_iter": { "type": "integer", "minimum": 1 }
      }
    },
    "RecursiveGridKnobs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "levels": { "type": "integer", "minimum": 1, "default": 2 },
        "shrink": { "type": "number", "exclusiveMinimum": 0, "default": 0.5 },
        "resolution": { "type": "integer", "minimum": 2, "default": 3 }
      }
    },
    "PersistBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "name"],
      "properties": {
        "root": { "type": "string" },
        "name": { "type": "string" }
      }
    }
  }
}
